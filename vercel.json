{
  "regions": ["fra1"],
  "ignoreCommand": "exit 1",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/scrape-usos-registrations.ts": {
      "maxDuration": 60
    },
    "api/scrape-uj-events.ts": {
      "maxDuration": 60
    },
    "api/scrape-faculty-announcements.ts": {
      "maxDuration": 300
    },
    "api/scrape-discounts.ts": {
      "maxDuration": 60
    },
    "api/prewarm-chat.ts": {
      "maxDuration": 30
    },
    "api/diag/cache-stats.ts": {
      "maxDuration": 10
    },
    "api/diag/health.ts": {
      "maxDuration": 10
    }
  },
  "crons": [
    { "path": "/api/scrape-uj-events", "schedule": "0 5 * * *" },
    { "path": "/api/scrape-faculty-announcements", "schedule": "0 * * * *" },
    { "path": "/api/scrape-usos-registrations", "schedule": "15 6 * * *" },
    { "path": "/api/scrape-usos-registrations", "schedule": "0 19 * * *" },
    { "path": "/api/extract-usos-registrations", "schedule": "30 6 * * *" },
    { "path": "/api/generate-briefings", "schedule": "0 6 * * 1" },
    { "path": "/api/scrape-discounts?op=expire", "schedule": "0 3 * * *" },
    { "path": "/api/scrape-discounts?op=scrape", "schedule": "0 4 * * *" }
  ]
}
