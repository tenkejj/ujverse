# Frontend (Vite) - safe to expose in client bundle

# Supabase publishable (anon) key + project URL.
# Preferowana nazwa to VITE_SUPABASE_PUBLISHABLE_KEY (nowy format `sb_publishable_*`),
# stary VITE_SUPABASE_ANON_KEY (JWT) jest akceptowany jako fallback.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Lokalny Meilisearch (dev): http://localhost:7700 + master key lub search-only key
VITE_MEILISEARCH_HOST=http://localhost:7700
VITE_MEILISEARCH_SEARCH_KEY=your-meilisearch-key
VITE_MEILISEARCH_INDEX=ujverse_content

# Server-side examples (do not expose in frontend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used by `api/sync-search.ts` (Vercel webhook endpoint)
MEILI_HOST=https://your-meilisearch-host
MEILI_MASTER_KEY=your-meilisearch-master-key
SECRET_WEBHOOK_KEY=your-random-webhook-secret

# Used by `api/_lib/llmService.ts` (Groq + chat)
GROQ_API_KEY=your-groq-api-key

# Used by `scripts/backfill-search.ts`, `seed-search.js` i Edge Function `sync-search`
MEILISEARCH_HOST=https://your-meilisearch-host
MEILISEARCH_ADMIN_KEY=your-meilisearch-admin-key
MEILISEARCH_INDEX=ujverse_content
SYNC_WEBHOOK_SECRET=your-random-sync-webhook-secret
