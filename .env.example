# Frontend (Vite) - safe to expose in client bundle
VITE_MEILISEARCH_HOST=https://your-meilisearch-host
VITE_MEILISEARCH_SEARCH_KEY=your-search-only-key
VITE_MEILISEARCH_INDEX=ujverse_content

# Server-side examples (do not expose in frontend)
# Used by `scripts/backfill-search.ts` and Supabase Edge Function `sync-search`.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MEILISEARCH_HOST=https://your-meilisearch-host
MEILISEARCH_ADMIN_KEY=your-meilisearch-admin-key
MEILISEARCH_INDEX=ujverse_content
SYNC_WEBHOOK_SECRET=your-random-sync-webhook-secret
